{
  "name": "@codex-login-tools/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build -w @codex-login-tools/shared && npm run build:web && tsc -p tsconfig.json",
    "build:web": "vite build --config ui/vite.config.ts",
    "dev:web": "vite --config ui/vite.config.ts",
    "test": "npm run build -w @codex-login-tools/shared && vitest run",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@codex-login-tools/shared": "file:../../packages/shared",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^8.3.0",
    "@vicons/ionicons5": "^0.13.0",
    "fastify": "^5.6.2",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.1.3",
    "vitest": "^3.2.4"
  }
}
